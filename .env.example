# Copy this file to .env and fill in GEMINI_API_KEY.
# Gemini API key used when
DEVICE=auto
OUTPUT_DIR=./output
THRESHOLD=0.5
IMAGE_THRESHOLD=0.2
NO_HEADING_DETECTION=false
HEADING_MAX_CHARS=180
NO_VLM_RISK_DETECTION=false
VLM_MAX_RISK_CROPS=12
VLM_LOW_TEXT_DENSITY=0.00025
# VLM/Gemini call gate. Keep but only call the VLM
# when OCR confidence is low. Options: low_confidence, always, never, risk_or_low_confidence.
VLM_POSTCHECK_TRIGGER=low_confidence
VLM_OCR_AVG_CONFIDENCE_THRESHOLD=0.86
VLM_OCR_LOW_LINE_THRESHOLD=0.78
VLM_OCR_LOW_LINE_RATIO=0.20
VLM_OCR_VERY_LOW_LINE_THRESHOLD=0.60
VLM_OCR_MIN_LINES=1
VLM_LAYOUT_AVG_CONFIDENCE_THRESHOLD=0.60
VLM_LAYOUT_LOW_REGION_THRESHOLD=0.55
VLM_LAYOUT_LOW_REGION_RATIO=0.35
# Gemini post-check. Set true/false here; no CLI flag is needed.

AI_POSTCHECK=false
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4.1-mini
AI_SYSTEM_PROMPT=conf/ai_postcheck_system_prompt.txt
AI_MAX_PAGES=6
AI_IMAGE_MAX_SIDE=1600
AI_TIMEOUT=180
AI_RESPONSE_FORMAT=json_object
AI_INCLUDE_IMAGES=true
AI_TEMPERATURE=0
AI_MAX_TOKENS=
AI_MAX_INPUT_CHARS=40000
