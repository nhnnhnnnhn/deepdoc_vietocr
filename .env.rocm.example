# Copy values into .env or pass them via the shell before docker compose up.
# docker-compose.rocm.yml reads .env at runtime and Dockerfile.rocm does not bake secrets into the image.

AI_POSTCHECK=false
AI_BASE_URL=http://host.docker.internal:11434/v1
AI_API_KEY=
AI_MODEL=qwen3-vl:8b
AI_SYSTEM_PROMPT=conf/ai_postcheck_system_prompt.txt
AI_MAX_PAGES=3
AI_IMAGE_MAX_SIDE=1200
AI_TIMEOUT=180
AI_RESPONSE_FORMAT=json_object
AI_INCLUDE_IMAGES=true
AI_TEMPERATURE=0
AI_MAX_TOKENS=

DEVICE=auto
REQUIRE_GPU=1
WEB_PORT=8000
OCR_CORRECTION_MEMORY_PATH=/app/web_runs/ocr_correction_memory.json

# ROCm-specific: control which AMD GPU(s) are visible inside the container.
# 0 = first GPU only, 0,1 = first two GPUs, unset = all GPUs.
HIP_VISIBLE_DEVICES=0
